---
import profileData from '../../data/profile.json';
import { AnimatedSection } from '../ui/AnimatedSection';
import { Counter } from '../ui/Counter';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { stats } = profileData;
---

<section id="about" class="py-24 border-t border-border/20">
  <AnimatedSection client:visible>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <!-- Text -->
      <div class="space-y-6">
        <h2 class="text-4xl md:text-5xl font-black text-foreground tracking-tight">
          {t("about.title")}
        </h2>
        <div class="h-1.5 w-20 bg-gradient-main rounded-full"></div>
        <div class="space-y-4 pt-4">
          <p class="text-muted-foreground leading-relaxed text-lg font-medium">
            {t("about.summary1")}
          </p>
          <p class="text-muted-foreground leading-relaxed text-lg font-medium">
            {t("about.summary2")}
          </p>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-6 relative">
        <div class="absolute inset-0 bg-accent-cyan/5 blur-3xl -z-10 rounded-full"></div>
        <div class="p-8 glass rounded-2xl border border-border/40 glass-hover overflow-hidden relative group">
          <div class="absolute top-0 right-0 w-16 h-16 bg-accent-cyan/5 rounded-full -mr-8 -mt-8 group-hover:bg-accent-cyan/10 transition-colors"></div>
          <h3 class="text-5xl text-accent-cyan font-black mb-2 tracking-tighter">
            <Counter client:visible value={stats.experienceYears} suffix="+" />
          </h3>
          <p class="text-muted-foreground text-xs uppercase tracking-[0.2em] font-bold">{t("about.yearsExp")}</p>
        </div>
        <div class="p-8 glass rounded-2xl border border-border/40 glass-hover overflow-hidden relative group">
          <div class="absolute top-0 right-0 w-16 h-16 bg-accent-indigo/5 rounded-full -mr-8 -mt-8 group-hover:bg-accent-indigo/10 transition-colors"></div>
          <h3 class="text-5xl text-accent-indigo font-black mb-2 tracking-tighter">
            <Counter client:visible value={stats.projectsCompleted} suffix="+" />
          </h3>
          <p class="text-muted-foreground text-xs uppercase tracking-[0.2em] font-bold">{t("about.projects")}</p>
        </div>
        <div class="p-8 glass rounded-2xl border border-border/40 glass-hover overflow-hidden relative group">
          <div class="absolute top-0 right-0 w-16 h-16 bg-accent-violet/5 rounded-full -mr-8 -mt-8 group-hover:bg-accent-violet/10 transition-colors"></div>
          <h3 class="text-5xl text-accent-violet font-black mb-2 tracking-tighter">
            <Counter client:visible value={stats.companiesWorked} />
          </h3>
          <p class="text-muted-foreground text-xs uppercase tracking-[0.2em] font-bold">{t("about.companies")}</p>
        </div>
        <div class="p-8 glass rounded-2xl border border-border/40 glass-hover overflow-hidden relative group">
          <div class="absolute top-0 right-0 w-16 h-16 bg-accent-cyan/5 rounded-full -mr-8 -mt-8 group-hover:bg-accent-cyan/10 transition-colors"></div>
          <h3 class="text-5xl text-accent-cyan font-black mb-2 tracking-tighter">
            <Counter client:visible value={stats.countries} />
          </h3>
          <p class="text-muted-foreground text-xs uppercase tracking-[0.2em] font-bold">{t("about.countries")}</p>
        </div>
      </div>
    </div>
  </AnimatedSection>
</section>
